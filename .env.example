# FamilySearch OAuth app credentials
FS_CLIENT_ID=            # Required
FS_CLIENT_SECRET=        # Optional (enables client_credentials where allowed)
FS_ENVIRONMENT=sandbox   # sandbox|production

# Optional: if you add scripts that use username/password login (not used by default)
FS_USERNAME=
FS_PASSWORD=

# Optional: local LLM settings (only needed if you add AI summarization scripts)
OLLAMA_MODEL=
OLLAMA_BASE_URL=

# Optional: external AI provider keys (only needed if you add AI scripts)
ANTHROPIC_API_KEY=

# Historical context source API keys (optional but recommended)
WHE_API_KEY=             # World History Encyclopedia API key
DPLA_API_KEY=            # Digital Public Library of America API key
EUROPEANA_API_KEY=       # Europeana API key
# No key needed: Chronicling America, Our World In Data, LOC Collections

# Optional: directory to store downloaded data (defaults to current directory)
DATA_DIR=./
