# Node modules
node_modules/
npm-debug.log
yarn.lock

# Environment
.env # Never commit secrets (FamilySearch OAuth client id/secret, tokens, etc.)
.env.local

# macOS / OS junk
.DS_Store

# FamilySearch token cache (generated by scripts/fs-auth.js)
data/.fs-token-cache.json

# -------------------------------------------------------------------
# Personal / private genealogy data (keep public repo code-only)
# -------------------------------------------------------------------
# Raw GEDCOM exports can contain living-person info.
data/raw/

# Converted JSON contains full extracted person/family data.
data/json/*.json

# Derived reports/inventories/mappings (generated from private data).
data/media-inventory.json
data/fs-mapping.json
data/verification-report-*.json
data/manual-review.json
data/patch-log.json

# Book generator caches (generated locally)
data/image-cache/
data/narrative-cache/
data/place-cache/

# Logs
data/json/warnings-*.log
*.log

# Document system: per-person metadata and any unassigned files are private.
documents/by-person/
documents/unassigned/

# Generated reports (local output only)
reports/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# IMPORTANT: Data folder is NOT ignored — family genealogy data should be versioned.
# However, data/raw/*.ged files may contain private information about living persons.
# Consider using a PRIVATE REPOSITORY if this data includes sensitive information.
# If you need privacy, add this line to your local .git/config:
# git config core.sparseCheckout true
# Then manage which files are tracked separately.
